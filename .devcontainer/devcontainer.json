{
  "name": "sandbox-webcg",
  "dockerComposeFile": "compose.yaml",
  "service": "app",
  "workspaceFolder": "/workspaces/sandbox-webcg",
  "initializeCommand": "sh -c 'test -n \"$SSH_AUTH_SOCK\" || { echo \"SSH_AUTH_SOCK is not set on the host.\" >&2; exit 1; }'",
  "overrideCommand": false,
  "remoteUser": "node",
  "remoteEnv": {
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "SSH_AUTH_SOCK": "/home/node/.ssh/ssh_auth.sock"
  },
  "mounts": [
      "source=${localWorkspaceFolder}/..,target=/workspaces,type=bind,consistency=cached",
      "source=${localEnv:HOME}/.codex,target=/host_config/.codex,type=bind,readonly,consistency=cached",
      "source=${localEnv:HOME}/.ssh,target=/host_config/.ssh,type=bind,readonly,consistency=cached",
      "source=${localEnv:HOME}/.gitconfig,target=/host_config/.gitconfig,type=bind,readonly,consistency=cached",
      "source=${localEnv:SSH_AUTH_SOCK},target=/host_config/ssh_auth.sock,type=bind,readonly,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
